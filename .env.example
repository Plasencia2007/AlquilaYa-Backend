# ==============================================================
# AlquilaYa — Plantilla de variables de entorno
# ==============================================================
# Copia este archivo a .env y reemplaza los valores placeholder
# por los reales. El archivo .env NUNCA se sube a git.
# ==============================================================

# --- Bases de datos (solo locales con docker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiar-por-password-local
MYSQL_USER=root
MYSQL_PASSWORD=cambiar-por-password-local

# --- JWT (debe ser la misma en usuarios, propiedades y catalogos) ---
JWT_SECRET=cambiar-por-secreto-aleatorio-de-al-menos-256-bits
JWT_EXPIRATION=86400000

# --- Cloudinary (https://cloudinary.com/console) ---
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# --- Mercado Pago (https://www.mercadopago.com.pe/developers/panel/app) ---
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxx
MP_NOTIFICATION_URL=https://tu-tunel.ngrok-free.dev/api/v1/pagos/webhook

# --- ngrok (https://dashboard.ngrok.com/get-started/your-authtoken) ---
NGROK_AUTHTOKEN=tu-authtoken-aqui
NGROK_DOMAIN=tu-dominio.ngrok-free.dev
