# ==============================================================
# AlquilaYa — Plantilla de variables de entorno
# ==============================================================
# Copia este archivo a .env y reemplaza los valores placeholder
# por los reales. El archivo .env NUNCA se sube a git.
# ==============================================================

# --- Bases de datos (solo locales con docker) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=oracle123
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# BD dedicada del chat in-app. Inicializada por database/init.sql.
POSTGRES_DB_MENSAJERIA=alquilaya_mensajeria
MYSQL_USER=root
MYSQL_PASSWORD=mysql123
MYSQL_HOST=localhost
MYSQL_PORT=3307

# --- Infraestructura Spring Cloud ---
# En docker-compose/k8s reemplazar por nombres de servicio (p.ej. http://discovery-server:8761/eureka/)
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
SPRING_CLOUD_CONFIG_URI=http://localhost:8888
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- CORS ---
# Lista separada por comas; admite patrones (p.ej. https://*.alquilaya.com). "*" NO es válido si allow-credentials=true.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- JWT (debe ser la misma en usuarios, propiedades, pagos y catalogos) ---
JWT_SECRET=cambiar-por-secreto-aleatorio-de-al-menos-256-bits
# 2h en ms. Para prod se recomienda ≤ 1h (3600000) + refresh tokens.
JWT_EXPIRATION=7200000

# --- Cloudinary (https://cloudinary.com/console) ---
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# --- Mercado Pago (https://www.mercadopago.com.pe/developers/panel/app) ---
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxx
# Secret para validar firma del webhook (panel MP > Webhooks > "Clave secreta")
# En producción DEBE estar seteado; vacío desactiva la validación (solo para desarrollo).
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=https://tu-tunel.ngrok-free.dev/api/v1/pagos/webhook
# URLs de retorno post-pago (producción debe apuntar al dominio real)
MP_BACK_URL_SUCCESS=http://localhost:3000/pago/exito
MP_BACK_URL_FAILURE=http://localhost:3000/pago/fallo
MP_BACK_URL_PENDING=http://localhost:3000/pago/pendiente

# --- ngrok (https://dashboard.ngrok.com/get-started/your-authtoken) ---
NGROK_AUTHTOKEN=tu-authtoken-aqui
NGROK_DOMAIN=tu-dominio.ngrok-free.dev

# --- Notificaciones (servicio Node.js) ---
# Secret compartido entre los servicios Java y el servicio Node.
# Cualquier llamada HTTP a /api/v1/notifications/whatsapp/* exige header x-api-key con este valor.
# Generar con: openssl rand -hex 32
INTERNAL_API_KEY=cambiar-por-secreto-aleatorio-de-32-bytes
NOTIFICATION_SERVICE_URL=http://localhost:8081

# --- Hibernate / JPA ---
# En producción usar "validate" (requiere migraciones Flyway) o "none". Nunca "update" en prod.
HIBERNATE_DDL_AUTO=update
SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false

# --- Gmail SMTP (forgot-password) ---
# Cuenta Gmail real con 2FA habilitado + App Password de 16 chars (sin espacios).
# Generar app password: Google Account → Security → App passwords → "Mail" + "Otro: AlquilaYa".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-correo@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# --- URL del frontend (para construir links de reset password en emails) ---
APP_BASE_URL=http://localhost:3000

# --- Google OAuth (login con Google) ---
# Crear OAuth Client ID Web en https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=

# --- Cloudflare Turnstile (captcha en /register) ---
# Crear site en https://dash.cloudflare.com/ → Turnstile → Add Site
# Domain: localhost
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
CAPTCHA_ENABLED=false
