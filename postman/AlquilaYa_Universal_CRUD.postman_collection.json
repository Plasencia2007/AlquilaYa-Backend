		{
			"name": "04. TABLA RESERVAS",
			"item": [
				{
					"name": "Solicitar Reserva",
					"request": {
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"propiedadId\": 1,\n  \"fechaInicio\": \"2026-05-01\",\n  \"fechaFin\": \"2026-11-30\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/v1/reservas"
					}
				},
				{
					"name": "Mis Reservas (Estudiante)",
					"request": { "method": "GET", "url": "{{base_url}}/api/v1/reservas/mis" }
				},
				{
					"name": "Gestionar Reservas (Arrendador)",
					"request": { "method": "GET", "url": "{{base_url}}/api/v1/reservas/arrendador" }
				},
				{
					"name": "Filtrar por Estado",
					"request": { "method": "GET", "url": "{{base_url}}/api/v1/reservas/arrendador/estado/SOLICITADA" }
				},
				{
					"name": "Obtener por ID",
					"request": { "method": "GET", "url": "{{base_url}}/api/v1/reservas/1" }
				},
				{
					"name": "Actualizar (CRUD Básico)",
					"request": {
						"method": "PUT",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"montoTotal\": 1500.00,\n  \"estado\": \"APROBADA\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/v1/reservas/1"
					}
				},
				{
					"name": "Aprobar",
					"request": { "method": "PATCH", "url": "{{base_url}}/api/v1/reservas/1/aprobar" }
				},
				{
					"name": "Rechazar",
					"request": {
						"method": "PATCH",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"motivo\": \"Ya no está disponible\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/v1/reservas/1/rechazar"
					}
				},
				{
					"name": "Cancelar",
					"request": { "method": "PATCH", "url": "{{base_url}}/api/v1/reservas/1/cancelar" }
				},
				{
					"name": "Finalizar",
					"request": { "method": "PATCH", "url": "{{base_url}}/api/v1/reservas/1/finalizar" }
				},
				{
					"name": "Eliminar",
					"request": { "method": "DELETE", "url": "{{base_url}}/api/v1/reservas/1" }
				}
			]
		},
