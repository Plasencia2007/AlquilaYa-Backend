				{
					"name": "Actualizar (Editar Todo)",
					"request": {
						"method": "PUT",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"titulo\": \"Habitación Suite Ejecutiva\",\n  \"descripcion\": \"Habitación de lujo con todos los servicios\",\n  \"precio\": 1200.00,\n  \"direccion\": \"Av. Universitaria 456\",\n  \"area\": 25.5,\n  \"nroPiso\": 3,\n  \"estaDisponible\": true,\n  \"detallesPerfil\": \"...\",\n  \"serviciosIncluidos\": [\"WIFI\", \"AGUA\", \"LUZ\", \"LIMPIEZA\"],\n  \"reglas\": [\"NO_MASCOTAS\", \"NO_FUMAR\"],\n  \"latitud\": -12.0431,\n  \"longitud\": -77.0282\n}",
