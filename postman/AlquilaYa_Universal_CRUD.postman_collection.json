				},
				{
					"name": "Obtener por ID",
					"request": { "method": "GET", "url": "{{base_url}}/api/v1/usuarios/1" }
				},
				{
					"name": "Actualizar",
					"request": {
						"method": "PUT",
						"body": {
							"mode": "raw",
							"raw": "{\"nombre\": \"Nombre Editado\"}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{base_url}}/api/v1/usuarios/1"
					}
				},
				{
					"name": "Eliminar",
					"request": { "method": "DELETE", "url": "{{base_url}}/api/v1/usuarios/1" }
				}
			]
		},
		{
